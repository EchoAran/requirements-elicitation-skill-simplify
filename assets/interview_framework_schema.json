{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InterviewFramework",
  "type": "object",
  "required": [
    "schema_version",
    "phase",
    "current_topic_id",
    "topics",
    "open_questions",
    "contradictions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "3.0.0"
    },
    "phase": {
      "type": "string",
      "enum": ["start", "runtime", "complete"]
    },
    "current_topic_id": {
      "type": ["string", "null"]
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "priority", "status", "slots"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "status": {
            "type": "string",
            "enum": ["unstarted", "active", "partially_filled", "sufficient", "blocked", "skipped"]
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "slots": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "value", "confidence", "status", "evidence"],
              "properties": {
                "name": { "type": "string" },
                "value": {},
                "confidence": {
                  "type": "string",
                  "enum": ["confirmed", "supported_inference", "open"],
                  "description": "Semantic constraints: empty->open; filled must not use open; conflicted should not use open."
                },
                "status": {
                  "type": "string",
                  "enum": ["empty", "filled", "open_question", "conflicted"]
                },
                "contradiction_severity": {
                  "type": ["string", "null"],
                  "enum": ["low", "medium", "high", null],
                  "description": "Required when status=conflicted."
                },
                "evidence": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "description": "Direct excerpt from user's input supporting this slot value."
                  }
                },
                "last_updated_turn": {
                  "type": ["integer", "null"]
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "kind", "status"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["general", "contradiction", "assumption", "dependency"]
          },
          "related_slot_ref": { "type": ["string", "null"] },
          "severity": {
            "type": ["string", "null"],
            "enum": ["low", "medium", "high", null]
          },
          "status": {
            "type": "string",
            "enum": ["open", "resolved"]
          }
        },
        "additionalProperties": false
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "slot_ref", "claim_a", "claim_b", "severity", "status"],
        "properties": {
          "id": { "type": "string" },
          "slot_ref": { "type": "string" },
          "claim_a": { "type": "string" },
          "claim_b": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "status": {
            "type": "string",
            "enum": ["open", "resolved"]
          },
          "resolution_note": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
